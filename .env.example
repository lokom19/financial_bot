# ============================================================
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Tinkoff Invest API (for data collection)
INVEST_TOKEN=your_tinkoff_invest_token_here

# Kafka Configuration (for model trainer)
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=data_collection_status
CONSUMER_GROUP=model_trainer_group
KAFKA_TOPIC_PRODUCER=model_trainer_status

# Directory Configuration
DATAFRAMES_DIR=/path/to/dataframes
OUTPUT_DIR=/path/to/output
WAIT_TIMEOUT=15000
